# Copy this file somewhere private, edit values, then pass:
#   ./ios-device-runner/scripts/run-ios-device.sh --config /path/to/my-app.env
#
# Shell-compatible KEY=value syntax. Quote values with spaces.

# Repo/worktree root. Optional when running from inside repo.
REPO=/path/to/repo

# iOS app directory, relative to REPO or absolute.
APP_DIR=apps/MyApp

# Choose one. If omitted and APP_DIR contains exactly one .xcodeproj, script auto-detects.
# PROJECT=apps/MyApp/MyApp.xcodeproj
# WORKSPACE=apps/MyApp/MyApp.xcworkspace

# Xcode scheme. If omitted, defaults to project basename.
SCHEME=MyApp

# Optional build settings.
CONFIGURATION=Debug
# DERIVED_DATA=apps/MyApp/build/DerivedData-device

# Optional device. If omitted, script auto-detects one physical iPhone or prompts.
# IOS_DEVICE_ID=00000000-0000000000000000
